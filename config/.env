# .env.example
# 复制这个文件为 .env 并填入你的值

# --- 通用设置 ---
TZ=Asia/Shanghai

# --- 更新检查设置 ---
POLL_INTERVAL=1800
INITIAL_CHECK_DELAY=15
UPDATE_RETRY_BACKOFF=1800
CLEANUP=true
AUTO_UPDATE=true
NOTIFY_ON_AVAILABLE_UPDATE=true
UPDATE_SOURCE=auto

# --- Notifier (Telegram) 设置 ---
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE
SERVER_NAME=My_Server_Name
PRIMARY_SERVER=false
# 仅主服务器轮询 Telegram Bot，避免 getUpdates 冲突
ENABLE_BOT_POLLING=true

# --- Notifier 功能设置 ---
ENABLE_ROLLBACK=true
MONITORED_CONTAINERS=
HEALTHCHECK_MAX_AGE=120
